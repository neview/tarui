{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-app",
  "version": "1.4.0",
  "identifier": "com.tauri-app.tauri-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tauri-app",
        "width": 1000,
        "height": 700,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "scripts/**/*": "scripts/"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/neview/tarui/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyMDUxOTE1RTNCMThDNkYKUldSdmpMSGpGUmtGRWc0NjBudW1KWEM2SnRrZEc2blVQV05IeEtxdjF0cVk4L3dtR3FPVks2ZUUK"
    }
  }
}
